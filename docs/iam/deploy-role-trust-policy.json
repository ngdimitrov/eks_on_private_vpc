{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSsoOrIamUserToAssumeWithMfa",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::REPLACE-ME-ACCOUNT-ID:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "Bool": {
          "aws:MultiFactorAuthPresent": "true"
        },
        "NumericLessThan": {
          "aws:MultiFactorAuthAge": "3600"
        }
      }
    }
  ]
}
