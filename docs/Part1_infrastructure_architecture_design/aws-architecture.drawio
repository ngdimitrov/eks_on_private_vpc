        <mxCell id="rds-primary" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#BA7517;fontSize=12;fontColor=#412402;align=center;verticalAlign=middle;arcSize=8;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;RDS PostgreSQL primary (AZ-a)&lt;br&gt;10.10.21.0/24&lt;br&gt;Multi-AZ, KMS-encrypted, per-client CMK&lt;/font&gt;" vertex="1">
          <mxGeometry height="122.5" width="355" x="80" y="1320" as="geometry" />
